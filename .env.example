# Archivo de ejemplo - Copia este archivo como .env y completa con tus datos

# Token del bot de Discord
DISCORD_TOKEN=tu_token_aqui

# ==================== CONFIGURACIÓN DE DEBUG ====================

# Habilitar comandos /debug (1 = activado, 0 = desactivado)
# IMPORTANTE: En producción siempre debe estar en 0
# Los comandos /debug escriben directamente en las tablas de producción
DEBUG=0

# Lista de usuarios permitidos para usar comandos /debug
# IDs de Discord separados por comas (sin espacios)
# Ejemplo: DEBUG_ALLOWLIST=123456789,987654321
DEBUG_ALLOWLIST=

